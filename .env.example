# ── LLM Provider Configuration ─────────────────────────────────────────────
# Set the providers you want to use.
# The framework is provider-agnostic via LiteLLM.

# Anthropic (cloud agents — Risk Aggregator, Coverage Gap, Pricing, Explainability)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI (baseline comparison only)
OPENAI_API_KEY=your_openai_key_here

# Local Gemma 4 via Ollama (privacy-sensitive agents)
# Install Ollama: https://ollama.ai
# Then run: ollama pull gemma4
OLLAMA_BASE_URL=http://localhost:11434

# ── Model Configuration ──────────────────────────────────────────────────────
# Local model for privacy-sensitive agents
LOCAL_MODEL=ollama/gemma2  # Use gemma2 if gemma4 not yet available in Ollama

# Cloud model for complex reasoning agents
CLOUD_MODEL=claude-sonnet-4-6

# Fallback: run everything on cloud if no local setup
FALLBACK_ALL_CLOUD=false

# ── Routing Configuration ────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.80

# ── Database (optional — for audit trail persistence) ───────────────────────
DATABASE_URL=postgresql://localhost/governing_edge
